# Konfigurasi Aplikasi Swantara Gate
# Copy file ini ke .env dan sesuaikan nilainya

# Port untuk Admin Panel (HTTP)
ADMIN_HTTP_PORT=8081

# Port untuk Admin Panel (HTTPS)
ADMIN_HTTPS_PORT=8443

# Port untuk Proxy Gateway (HTTP)
PROXY_HTTP_PORT=8000

# Port untuk Proxy Gateway (HTTPS)
PROXY_HTTPS_PORT=8440

# Path ke database SQLite
DATABASE_PATH=./data/database.db

# Path ke file SQL untuk inisialisasi database
DATABASE_SQL_PATH=./data/database.sql

# Path ke sertifikat SSL untuk Admin (HTTPS)
ADMIN_SSL_CERT_PATH=./ssl/admin/cert.pem
ADMIN_SSL_KEY_PATH=./ssl/admin/key.pem

# Path ke sertifikat SSL untuk Proxy (HTTPS)
PROXY_SSL_CERT_PATH=./ssl/proxy/cert.pem
PROXY_SSL_KEY_PATH=./ssl/proxy/key.pem

# Environment (development, production)
APP_ENV=development

# Log level (debug, info, warn, error)
LOG_LEVEL=info
