}

.preset-btn {
    padding: 6px 12px;
    font-size: 12px;
    border: 1px solid var(--border);
    background: var(--surface);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: var(--transition-fast);
}

.preset-btn:hover {
    background: var(--accent-light);
