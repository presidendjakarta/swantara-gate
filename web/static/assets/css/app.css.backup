    color: var(--text-secondary);
    margin-bottom: 6px;
    display: block;
}

.mask-pattern {
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 11px;
    color: var(--accent);
    background: var(--accent-light);
    padding: 2px 6px;
