    }
}

@media (max-width: 768px) {
    .datetimepicker-grid.three-cols {
        grid-template-columns: 1fr;
    }
}


/* === default.blade.php === */

.df-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 24px;
}

.df-grid.three-cols {
    grid-template-columns: repeat(3, 1fr);
}

.df-grid.full-width {
    grid-template-columns: 1fr;
}

.df-section-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--accent);
    display: flex;
    align-items: center;
    gap: 8px;
}

.df-section-title i {
    color: var(--accent);
}

.df-example {
    margin-bottom: 20px;
}

.df-example:last-child {
    margin-bottom: 0;
}

.df-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 8px;
    display: block;
}

.df-hint {
    font-size: 11px;
    color: var(--text-tertiary);
    background: var(--bg-secondary);
    padding: 2px 6px;
    border-radius: 4px;
    margin-left: 8px;
}

.df-helper {
    font-size: 11px;
    color: var(--text-tertiary);
    margin-top: 4px;
    display: flex;
    align-items: center;
    gap: 4px;
}

/* Form Variants */
.form-horizontal .form-group {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 16px;
    align-items: start;
}

.form-inline {
    display: flex;
    gap: 12px;
    align-items: end;
}

.form-inline .form-group {
    flex: 1;
    margin-bottom: 0;
}

.form-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
}

.form-row-2 {
    grid-template-columns: repeat(2, 1fr);
}

.form-row-3 {
    grid-template-columns: repeat(3, 1fr);
}

.form-row-4 {
    grid-template-columns: repeat(4, 1fr);
}

.form-actions {
    display: flex;
    gap: 12px;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
}

.form-divider {
    height: 1px;
    background: var(--border);
    margin: 24px 0;
}

.form-section {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.form-section i {
    color: var(--accent);
}

/* Badge */
.badge {
    display: inline-block;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    border-radius: 12px;
    margin-left: 8px;
}

.badge-primary {
    background: var(--accent-light);
    color: var(--accent);
}

.badge-success {
    background: var(--success-bg);
    color: var(--success);
}

.badge-warning {
    background: var(--warning-bg);
    color: var(--warning);
}

.badge-info {
    background: var(--info-bg);
    color: var(--info);
}

.feature-list {
    list-style: none;
    padding: 0;
}

.feature-list li {
    padding: 8px 0;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
}

.feature-list li i {
    color: var(--success);
    font-size: 14px;
}

.helper-text {
    font-size: 12px;
    color: var(--text-tertiary);
    margin-top: 6px;
    display: flex;
    align-items: center;
    gap: 4px;
}

.code-block {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px;
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 12px;
    overflow-x: auto;
    margin-top: 16px;
}

@media (max-width: 1200px) {
    .df-grid {
        grid-template-columns: 1fr;
    }
    
    .df-grid.three-cols {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .form-row-4 {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .df-grid.three-cols {
        grid-template-columns: 1fr;
    }
    
    .form-row-2,
    .form-row-3,
    .form-row-4 {
        grid-template-columns: 1fr;
    }
    
    .form-horizontal .form-group {
        grid-template-columns: 1fr;
    }
    
    .form-inline {
        flex-direction: column;
        align-items: stretch;
    }
}


/* === dual-list.blade.php === */

.dual-list-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 24px;
}

.dual-list-grid.full-width {
    grid-template-columns: 1fr;
}

.dl-section-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--accent);
    display: flex;
    align-items: center;
    gap: 8px;
}

.dl-section-title i {
    color: var(--accent);
}

.dl-example {
    margin-bottom: 20px;
}

.dl-example:last-child {
    margin-bottom: 0;
}

.dl-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 8px;
    display: block;
}

.dl-hint {
    font-size: 11px;
    color: var(--text-tertiary);
    background: var(--bg-secondary);
    padding: 2px 6px;
    border-radius: 4px;
    margin-left: 8px;
}

.dl-helper {
    font-size: 11px;
    color: var(--text-tertiary);
    margin-top: 4px;
    display: flex;
    align-items: center;
    gap: 4px;
}

/* Dual List Container */
.dual-list-container {
    display: flex;
    gap: 12px;
    align-items: center;
}

/* List Box */
.list-box {
    flex: 1;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    overflow: hidden;
}

.list-box-header {
    padding: 12px 14px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.list-box-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
}

.list-box-count {
    font-size: 11px;
    color: var(--text-tertiary);
    background: var(--surface);
    padding: 2px 8px;
    border-radius: 10px;
}

.list-box-search {
    padding: 10px;
    border-bottom: 1px solid var(--border);
}

.list-box-search input {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 13px;
    outline: none;
}

.list-box-search input:focus {
    border-color: var(--accent);
}

.list-box-items {
    max-height: 200px;
    overflow-y: auto;
}

.list-box-item {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: var(--transition-fast);
    display: flex;
    align-items: center;
    gap: 10px;
}

.list-box-item:last-child {
    border-bottom: none;
}

.list-box-item:hover {
    background: var(--accent-light);
}

.list-box-item.selected {
    background: var(--accent-light);
    border-left: 3px solid var(--accent);
}

.list-box-item input[type="checkbox"] {
    margin: 0;
}

.list-box-item-content {
    flex: 1;
}

.list-box-item-title {
    font-size: 13px;
    color: var(--text-primary);
    font-weight: 500;
    margin-bottom: 2px;
}

.list-box-item-desc {
    font-size: 11px;
    color: var(--text-tertiary);
}

/* Transfer Buttons */
.transfer-buttons {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.transfer-btn {
    width: 40px;
    height: 40px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-secondary);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
}

.transfer-btn:hover {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
}

.transfer-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

/* Badge */
.badge {
    display: inline-block;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    border-radius: 12px;
    margin-left: 8px;
}

.badge-primary {
    background: var(--accent-light);
    color: var(--accent);
}

.badge-success {
    background: var(--success-bg);
    color: var(--success);
}

.badge-warning {
    background: var(--warning-bg);
    color: var(--warning);
}

.badge-info {
    background: var(--info-bg);
    color: var(--info);
}

.divider {
    height: 1px;
    background: var(--border);
    margin: 20px 0;
}

.feature-list {
    list-style: none;
    padding: 0;
}

.feature-list li {
    padding: 8px 0;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
}

.feature-list li i {
    color: var(--success);
    font-size: 14px;
}

.helper-text {
    font-size: 12px;
    color: var(--text-tertiary);
    margin-top: 6px;
    display: flex;
    align-items: center;
    gap: 4px;
}

.code-block {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px;
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 12px;
    overflow-x: auto;
    margin-top: 16px;
}

@media (max-width: 1200px) {
    .dual-list-grid {
        grid-template-columns: 1fr;
    }
    
    .dual-list-container {
        flex-direction: column;
    }
    
    .transfer-buttons {
        flex-direction: row;
    }
}

@media (max-width: 768px) {
    .dual-list-grid {
        grid-template-columns: 1fr;
    }
}


/* === elements.blade.php === */

.form-demo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 24px;
}

.form-demo-grid.three-cols {
    grid-template-columns: repeat(3, 1fr);
}

.form-demo-grid.full-width {
    grid-template-columns: 1fr;
}

.code-preview {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px;
    margin-top: 16px;
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 12px;
    overflow-x: auto;
}

.code-preview code {
    color: var(--text-primary);
}

.badge {
    display: inline-block;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    border-radius: 12px;
    margin-left: 8px;
}

.badge-primary {
    background: var(--accent-light);
    color: var(--accent);
}

.badge-success {
    background: var(--success-bg);
    color: var(--success);
}

.badge-warning {
    background: var(--warning-bg);
    color: var(--warning);
}

.badge-danger {
    background: var(--danger-bg);
    color: var(--danger);
}

.form-section-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--accent);
    display: flex;
    align-items: center;
    gap: 8px;
}

.form-section-title i {
    color: var(--accent);
}

.input-with-icon {
    position: relative;
}

.input-with-icon i {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-tertiary);
    font-size: 14px;
}

.input-with-icon input {
    padding-left: 40px;
}

.button-group {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.button-group .btn {
    flex: 0 0 auto;
}

.size-demo {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
}

.size-label {
    min-width: 60px;
    font-size: 12px;
    color: var(--text-secondary);
    font-weight: 500;
}

.state-demo {
    margin-bottom: 16px;
}

.state-demo:last-child {
    margin-bottom: 0;
}

.helper-text {
    font-size: 12px;
    color: var(--text-tertiary);
    margin-top: 6px;
    display: flex;
    align-items: center;
    gap: 4px;
}

.error-text {
    color: var(--danger);
}

.success-text {
    color: var(--success);
}

.divider {
