        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .form-demo-grid.three-cols {
        grid-template-columns: 1fr;
    }
    
    .button-group {
        flex-direction: column;
    }
    
    .button-group .btn {
