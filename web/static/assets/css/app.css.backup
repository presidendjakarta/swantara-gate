    }
}


/* === file-upload.blade.php === */

.file-upload-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 24px;
}

.file-upload-grid.three-cols {
    grid-template-columns: repeat(3, 1fr);
}

.file-upload-grid.full-width {
    grid-template-columns: 1fr;
}

.fu-section-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--accent);
    display: flex;
    align-items: center;
    gap: 8px;
}

.fu-section-title i {
    color: var(--accent);
}

.fu-example {
    margin-bottom: 20px;
}

.fu-example:last-child {
    margin-bottom: 0;
}

.fu-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 8px;
    display: block;
}

.fu-hint {
    font-size: 11px;
    color: var(--text-tertiary);
    background: var(--bg-secondary);
    padding: 2px 6px;
    border-radius: 4px;
    margin-left: 8px;
}

.fu-helper {
    font-size: 11px;
    color: var(--text-tertiary);
    margin-top: 4px;
    display: flex;
    align-items: center;
    gap: 4px;
}

/* Upload Zone */
.upload-zone {
    border: 2px dashed var(--border);
    border-radius: var(--radius-md);
    padding: 40px;
    text-align: center;
    cursor: pointer;
    transition: var(--transition-fast);
    background: var(--surface);
}

.upload-zone:hover,
.upload-zone.drag-over {
    border-color: var(--accent);
    background: var(--accent-light);
}

.upload-zone.drag-over {
    transform: scale(1.02);
}

.upload-zone-icon {
    font-size: 48px;
    color: var(--text-tertiary);
    margin-bottom: 12px;
}

.upload-zone-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
}

.upload-zone-desc {
    font-size: 13px;
    color: var(--text-tertiary);
    margin-bottom: 16px;
}

.upload-zone-btn {
    padding: 10px 24px;
    background: var(--accent);
    color: white;
    border-radius: var(--radius-sm);
    display: inline-block;
    font-size: 14px;
    font-weight: 500;
}

/* File Input */
.file-input-wrapper {
    position: relative;
    display: inline-block;
    width: 100%;
}

.file-input-wrapper input[type="file"] {
    position: absolute;
    opacity: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
}

.file-input-label {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    cursor: pointer;
    transition: var(--transition-fast);
}

.file-input-label:hover {
    border-color: var(--accent);
    background: var(--accent-light);
}

.file-input-icon {
    font-size: 20px;
    color: var(--accent);
}

.file-input-text {
    flex: 1;
    font-size: 14px;
    color: var(--text-secondary);
}

.file-input-name {
    font-size: 13px;
    color: var(--text-primary);
    font-weight: 500;
}

/* File List */
.file-list {
    margin-top: 12px;
}

.file-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    margin-bottom: 8px;
    background: var(--surface);
}

.file-item-icon {
    font-size: 24px;
    width: 32px;
    text-align: center;
}

.file-item-content {
    flex: 1;
}

.file-item-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 2px;
}

.file-item-size {
    font-size: 12px;
    color: var(--text-tertiary);
}

.file-item-remove {
    padding: 6px;
    border: none;
    background: transparent;
    color: var(--danger);
    cursor: pointer;
    border-radius: 4px;
    transition: var(--transition-fast);
}

.file-item-remove:hover {
    background: var(--danger-bg);
}

/* Progress Bar */
.upload-progress {
    margin-top: 8px;
}

.progress-bar-bg {
    height: 6px;
    background: var(--border);
    border-radius: 3px;
    overflow: hidden;
}

.progress-bar-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 3px;
    transition: width 0.3s ease;
}

.progress-bar-fill.success {
    background: var(--success);
}

.progress-text {
    display: flex;
    justify-content: space-between;
    margin-top: 4px;
    font-size: 11px;
    color: var(--text-tertiary);
}

/* File Preview */
.file-preview {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 12px;
    margin-top: 12px;
}

.file-preview-item {
    position: relative;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    aspect-ratio: 1;
}

.file-preview-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.file-preview-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: var(--transition-fast);
}

.file-preview-item:hover .file-preview-overlay {
    opacity: 1;
}

.file-preview-remove {
    padding: 8px;
    background: var(--danger);
    color: white;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    font-size: 16px;
}

/* Badge */
.badge {
    display: inline-block;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    border-radius: 12px;
    margin-left: 8px;
}

.badge-primary {
    background: var(--accent-light);
    color: var(--accent);
}

.badge-success {
    background: var(--success-bg);
    color: var(--success);
}

.badge-warning {
    background: var(--warning-bg);
    color: var(--warning);
}

.badge-info {
    background: var(--info-bg);
    color: var(--info);
}

.badge-danger {
    background: var(--danger-bg);
    color: var(--danger);
}

.divider {
    height: 1px;
    background: var(--border);
    margin: 20px 0;
}

.feature-list {
    list-style: none;
    padding: 0;
}

.feature-list li {
    padding: 8px 0;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
}

.feature-list li i {
    color: var(--success);
    font-size: 14px;
}

.helper-text {
    font-size: 12px;
    color: var(--text-tertiary);
    margin-top: 6px;
    display: flex;
    align-items: center;
    gap: 4px;
}

.code-block {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px;
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 12px;
    overflow-x: auto;
    margin-top: 16px;
}

@media (max-width: 1200px) {
    .file-upload-grid {
        grid-template-columns: 1fr;
    }
    
    .file-upload-grid.three-cols {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .file-upload-grid.three-cols {
        grid-template-columns: 1fr;
    }
}


/* === floating-labels.blade.php === */

.floating-labels-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 24px;
}

.floating-labels-grid.three-cols {
    grid-template-columns: repeat(3, 1fr);
}

.floating-labels-grid.full-width {
    grid-template-columns: 1fr;
}

.fl-section-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--accent);
    display: flex;
    align-items: center;
    gap: 8px;
}

.fl-section-title i {
    color: var(--accent);
}

/* Floating Label Base */
.floating-label-group {
    position: relative;
    margin-bottom: 20px;
}

.floating-label-group input,
.floating-label-group textarea,
.floating-label-group select {
    width: 100%;
    padding: 16px 14px 6px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    font-size: 14px;
    font-family: inherit;
    color: var(--text-primary);
    outline: none;
    transition: var(--transition-fast);
}

.floating-label-group input:focus,
.floating-label-group textarea:focus,
.floating-label-group select:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-light);
}

.floating-label-group label {
    position: absolute;
    top: 50%;
    left: 14px;
    transform: translateY(-50%);
    font-size: 14px;
    color: var(--text-tertiary);
    pointer-events: none;
    transition: var(--transition-fast);
    background: transparent;
    padding: 0 4px;
}

.floating-label-group textarea ~ label {
    top: 16px;
    transform: none;
}

/* Float the label when input has value or is focused */
.floating-label-group input:focus ~ label,
.floating-label-group input:not(:placeholder-shown) ~ label,
.floating-label-group textarea:focus ~ label,
.floating-label-group textarea:not(:placeholder-shown) ~ label,
.floating-label-group select:focus ~ label,
.floating-label-group select.has-value ~ label {
    top: 0;
    transform: translateY(-50%);
    font-size: 11px;
    color: var(--accent);
    background: var(--surface);
    font-weight: 500;
}

/* Valid State */
.floating-label-group input.is-valid,
.floating-label-group textarea.is-valid {
    border-color: var(--success);
}

.floating-label-group input.is-valid:focus,
.floating-label-group textarea.is-valid:focus {
    border-color: var(--success);
    box-shadow: 0 0 0 3px var(--success-bg);
}

.floating-label-group input.is-valid ~ label,
.floating-label-group textarea.is-valid ~ label {
    color: var(--success);
}

/* Invalid State */
.floating-label-group input.is-invalid,
.floating-label-group textarea.is-invalid {
    border-color: var(--danger);
}

.floating-label-group input.is-invalid:focus,
.floating-label-group textarea.is-invalid:focus {
    border-color: var(--danger);
    box-shadow: 0 0 0 3px var(--danger-bg);
}

.floating-label-group input.is-invalid ~ label,
.floating-label-group textarea.is-invalid ~ label {
    color: var(--danger);
}

/* Disabled State */
.floating-label-group input:disabled,
.floating-label-group textarea:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    background: var(--bg-secondary);
}

/* With Icon */
.floating-label-with-icon {
    position: relative;
}

.floating-label-with-icon i {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-tertiary);
    font-size: 16px;
    pointer-events: none;
    z-index: 1;
}

.floating-label-with-icon input {
    padding-left: 42px;
}

.floating-label-with-icon label {
    left: 42px;
}

.floating-label-with-icon input:focus ~ label,
.floating-label-with-icon input:not(:placeholder-shown) ~ label {
    left: 42px;
}

/* With Helper Text */
.helper-text {
    font-size: 12px;
    color: var(--text-tertiary);
    margin-top: 6px;
    display: flex;
    align-items: center;
    gap: 4px;
}

.helper-text.error-text {
    color: var(--danger);
}

.helper-text.success-text {
    color: var(--success);
}

/* Badge */
.badge {
    display: inline-block;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    border-radius: 12px;
    margin-left: 8px;
}

.badge-primary {
    background: var(--accent-light);
    color: var(--accent);
}

.badge-success {
    background: var(--success-bg);
    color: var(--success);
}

.badge-warning {
    background: var(--warning-bg);
    color: var(--warning);
}

.badge-info {
    background: var(--info-bg);
    color: var(--info);
}

.divider {
    height: 1px;
    background: var(--border);
    margin: 20px 0;
}

.feature-list {
    list-style: none;
    padding: 0;
}

.feature-list li {
    padding: 8px 0;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
}

.feature-list li i {
    color: var(--success);
    font-size: 14px;
}

.fl-example {
    margin-bottom: 16px;
}

.fl-example:last-child {
    margin-bottom: 0;
}

@media (max-width: 1200px) {
    .floating-labels-grid {
        grid-template-columns: 1fr;
    }
    
    .floating-labels-grid.three-cols {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .floating-labels-grid.three-cols {
        grid-template-columns: 1fr;
    }
}


/* === input-groups.blade.php === */

.input-groups-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 24px;
}

.input-groups-grid.three-cols {
    grid-template-columns: repeat(3, 1fr);
}

.input-groups-grid.full-width {
    grid-template-columns: 1fr;
}

.ig-section-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--accent);
    display: flex;
    align-items: center;
    gap: 8px;
}

.ig-section-title i {
    color: var(--accent);
}

/* Input Group Base */
.input-group {
    display: flex;
    align-items: stretch;
    width: 100%;
}

.input-group .form-control {
    flex: 1;
    border-radius: 0;
}

.input-group .form-control:first-child {
    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
}

.input-group .form-control:last-child {
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
}

.input-group .form-control:not(:first-child):not(:last-child) {
    border-radius: 0;
}

/* Input Group Addon */
.input-group-text {
    display: flex;
    align-items: center;
    padding: 10px 14px;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.5;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    white-space: nowrap;
}

.input-group-text:first-child {
    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
    border-right: none;
}

.input-group-text:last-child {
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    border-left: none;
}

.input-group-text i {
    font-size: 16px;
}

/* Input Group Button */
.input-group .btn {
    border-radius: 0;
}

.input-group .btn:first-child {
    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
}

.input-group .btn:last-child {
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
}

/* Badge */
.badge {
    display: inline-block;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    border-radius: 12px;
    margin-left: 8px;
}

.badge-primary {
    background: var(--accent-light);
    color: var(--accent);
}

.badge-success {
    background: var(--success-bg);
    color: var(--success);
}

.badge-warning {
    background: var(--warning-bg);
    color: var(--warning);
}

.badge-info {
    background: var(--info-bg);
    color: var(--info);
}

.divider {
    height: 1px;
    background: var(--border);
    margin: 20px 0;
}

.feature-list {
    list-style: none;
    padding: 0;
}

.feature-list li {
    padding: 8px 0;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
}

.feature-list li i {
    color: var(--success);
    font-size: 14px;
}

.helper-text {
    font-size: 12px;
    color: var(--text-tertiary);
    margin-top: 6px;
    display: flex;
    align-items: center;
    gap: 4px;
}

.ig-example {
    margin-bottom: 16px;
}

.ig-example:last-child {
    margin-bottom: 0;
}

.ig-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 6px;
    display: block;
}

@media (max-width: 1200px) {
    .input-groups-grid {
        grid-template-columns: 1fr;
    }
    
    .input-groups-grid.three-cols {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .input-groups-grid.three-cols {
        grid-template-columns: 1fr;
    }
    
    .input-group {
